FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
# Copy tarot images directly from source, bypassing Vite's copy
COPY --from=builder /app/public/tarot /usr/share/nginx/html/tarot
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
